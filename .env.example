# Copy this file to `.env` and fill in the keys for whichever provider(s)
# you've configured in API/config.json. `.env` is loaded automatically
# (via python-dotenv) and is gitignored — only `.env.example` is committed.
#
# You only need to fill in the variables for the providers you actually use.

# OpenRouter — https://openrouter.ai/keys
OR_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google AI Studio (Gemini) — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Google Cloud Vertex AI (Gemini) — requires an OAuth2 access token
# (e.g. `gcloud auth print-access-token`), a project, and a region.
GOOGLE_VERTEX_ACCESS_TOKEN=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Z.AI — used by both the "zai" (OpenAI-compatible) and "zai_coding"
# (Anthropic-compatible) providers — https://z.ai/manage-apikey/apikey-list
ZAI_API_KEY=
